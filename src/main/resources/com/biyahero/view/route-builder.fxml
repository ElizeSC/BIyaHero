<?xml version="1.0" encoding="UTF-8"?>

<?import java.lang.*?>
<?import java.util.*?>
<?import javafx.scene.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<?import java.net.URL?>
<?import javafx.geometry.Insets?>
<VBox spacing="15" styleClass="dialog-pane" stylesheets="@style.css" xmlns:fx="http://javafx.com/fxml" fx:controller="com.biyahero.controller.RouteBuilderController">
    <stylesheets>
        <URL value="@style.css" />
    </stylesheets>
    <padding><Insets top="20" right="20" bottom="20" left="20"/></padding>

    <Label text="ROUTE BUILDER" style="-fx-font-size: 20; -fx-text-fill: #e94560; -fx-font-weight: bold;"/>

    <HBox spacing="10">
        <TextField fx:id="txtRouteName" promptText="Route Name (e.g., Tacloban - Catbalogan)" HBox.hgrow="ALWAYS" styleClass="dialog-field"/>
        <TextField fx:id="txtBaseFare" promptText="Base Fare" prefWidth="100" styleClass="dialog-field"/>
    </HBox>

    <HBox spacing="15" VBox.vgrow="ALWAYS">
        <VBox spacing="5" HBox.hgrow="ALWAYS">
            <Label text="Available Stops" style="-fx-text-fill: white;"/>
            <ListView fx:id="lvAvailableStops" VBox.vgrow="ALWAYS" styleClass="dark-list-view"/>
        </VBox>

        <VBox alignment="CENTER" spacing="10">
            <Button text="ADD" onAction="#handleAddStop" styleClass="hero-button" prefWidth="80"/>
            <Button text="REMOVE" onAction="#handleRemoveStop" styleClass="hero-button" prefWidth="80"/>
        </VBox>

        <VBox spacing="5" HBox.hgrow="ALWAYS">
            <Label text="Route Sequence (Order Matters)" style="-fx-text-fill: #e94560;"/>
            <ListView fx:id="lvRouteSequence" VBox.vgrow="ALWAYS" styleClass="dark-list-view"/>
            <HBox spacing="5" alignment="CENTER">
                <Button text="MOVE UP" onAction="#handleMoveUp" style="-fx-background-color: #533483; -fx-text-fill: white;"/>
                <Button text="MOVE DOWN" onAction="#handleMoveDown" style="-fx-background-color: #533483; -fx-text-fill: white;"/>
            </HBox>
        </VBox>
    </HBox>

    <HBox spacing="10" alignment="CENTER_RIGHT">
        <Button text="CANCEL" onAction="#handleCancel" style="-fx-background-color: transparent; -fx-text-fill: gray;"/>
        <Button text="SAVE ROUTE" onAction="#handleSave" styleClass="hero-button" prefWidth="150"/>
    </HBox>
</VBox>


