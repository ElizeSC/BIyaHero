<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.*?>

<BorderPane prefHeight="700.0" prefWidth="1000.0" xmlns="http://javafx.com/javafx/8" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.biyahero.controller.MainController">
    <top>
        <HBox alignment="CENTER_LEFT" spacing="30" style="-fx-background-color: #1a252f; -fx-padding: 15;">
            <Label text="BiyaHero" style="-fx-text-fill: white; -fx-font-size: 20; -fx-font-weight: bold;" />

            <HBox spacing="15" alignment="CENTER">
                <Button onAction="#showDashboard" text="Dashboard" style="-fx-background-color: transparent; -fx-text-fill: white; -fx-cursor: hand;" />
                <Button onAction="#showVans" text="Vans &amp; Drivers" style="-fx-background-color: transparent; -fx-text-fill: white; -fx-cursor: hand;" />
                <Button text="Scheduled" style="-fx-background-color: transparent; -fx-text-fill: white; -fx-cursor: hand;" />
                <Button text="Reports" style="-fx-background-color: transparent; -fx-text-fill: white; -fx-cursor: hand;" />
            </HBox>

            <Region HBox.hgrow="ALWAYS" />
            <Label text="Admin" style="-fx-text-fill: #bdc3c7;" />
        </HBox>
    </top>

    <center>
        <VBox fx:id="contentArea" style="-fx-background-color: #ecf0f1;" />
    </center>
</BorderPane>