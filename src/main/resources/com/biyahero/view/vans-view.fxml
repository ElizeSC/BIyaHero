<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<VBox spacing="20" style="-fx-background-color: #f4f7f6;" xmlns="http://javafx.com/javafx/17.0.12" xmlns:fx="http://javafx.com/fxml/1">
    <padding>
        <Insets bottom="30" left="30" right="30" top="30" />
    </padding>

    <HBox alignment="CENTER_LEFT">
        <VBox spacing="5">
            <Label style="-fx-font-size: 28; -fx-font-weight: bold; -fx-text-fill: #2980b9;" text="Vans and Drivers" />
            <Label style="-fx-font-size: 14; -fx-text-fill: #7f8c8d;" text="Manage Van and Driver Records" />
        </VBox>
        <Region HBox.hgrow="ALWAYS" />

        <HBox style="-fx-background-color: #dcdde1; -fx-background-radius: 20; -fx-padding: 5;">
            <Button style="-fx-background-color: #2980b9; -fx-text-fill: white; -fx-background-radius: 15; -fx-padding: 5 20;" text="Vans" />
            <Button style="-fx-background-color: transparent; -fx-text-fill: #2f3640; -fx-padding: 5 20;" text="Drivers" />
        </HBox>
    </HBox>

    <HBox alignment="CENTER_LEFT" spacing="15">
        <TextField promptText="Search Van..." style="-fx-pref-width: 250; -fx-background-radius: 5;" />

        <ComboBox promptText="Display Van Information" style="-fx-pref-width: 200;" />

        <Region HBox.hgrow="ALWAYS" />

        <Button style="-fx-background-color: #27ae60; -fx-text-fill: white; -fx-font-weight: bold; -fx-padding: 8 20;" text="+ Add Van" />
    </HBox>

    <HBox alignment="CENTER_LEFT" spacing="10">
        <Label style="-fx-text-fill: #7f8c8d;" text="Sort by:" />
        <ComboBox promptText="Van ID" style="-fx-pref-width: 120;" />
    </HBox>

    <TableView fx:id="vanTable" style="-fx-background-radius: 10;" VBox.vgrow="ALWAYS">
        <columns>
            <TableColumn prefWidth="120" text="Van ID" />
            <TableColumn prefWidth="150" text="Plate Number" />
            <TableColumn prefWidth="150" text="Model" />
            <TableColumn prefWidth="100" text="Capacity" />
            <TableColumn prefWidth="120" text="Status" />
            <TableColumn prefWidth="180" text="Manage" />
        </columns>
    </TableView>
</VBox>
