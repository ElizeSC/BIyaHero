<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.geometry.*?>
<?import java.net.URL?>

<VBox spacing="20" styleClass="main-container"
      xmlns="http://javafx.com/javafx/17"
      xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="com.biyahero.controller.WalkInBookingController"
      prefWidth="380">
    <stylesheets><URL value="@style.css"/></stylesheets>
    <padding><Insets top="30" right="30" bottom="30" left="30"/></padding>

    <!-- Header -->
    <VBox spacing="5">
        <Label text="Quick Boarding"
               style="-fx-font-size: 20px; -fx-font-weight: 900;
                      -fx-text-fill: #0A0D2C;"/>
        <Label text="Roadside walk-in — no personal info needed."
               styleClass="sub-header"/>
    </VBox>

    <Separator/>

    <!-- Seat badge -->
    <HBox alignment="CENTER_LEFT" spacing="12">
        <Label text="Seat:" style="-fx-font-weight: bold; -fx-text-fill: #475569;"/>
        <Label fx:id="seatNumberLabel" text="—"
               style="-fx-font-size: 22px; -fx-font-weight: 900;
                      -fx-text-fill: #3E49BB;
                      -fx-background-color: #EEF2FF;
                      -fx-background-radius: 8;
                      -fx-padding: 4 16;"/>
    </HBox>

    <!-- Stops -->
    <GridPane hgap="15" vgap="12">
        <columnConstraints>
            <ColumnConstraints percentWidth="50"/>
            <ColumnConstraints percentWidth="50"/>
        </columnConstraints>

        <VBox GridPane.columnIndex="0" GridPane.rowIndex="0" spacing="5">
            <Label text="Pickup Stop"
                   style="-fx-font-weight: bold; -fx-text-fill: #475569;"/>
            <ComboBox fx:id="pickupStopCombo"
                      maxWidth="Infinity"
                      promptText="Boarded at..."/>
        </VBox>

        <VBox GridPane.columnIndex="1" GridPane.rowIndex="0" spacing="5">
            <Label text="Dropoff Stop"
                   style="-fx-font-weight: bold; -fx-text-fill: #475569;"/>
            <ComboBox fx:id="dropoffStopCombo"
                      maxWidth="Infinity"
                      promptText="Getting off at..."/>
        </VBox>
    </GridPane>

    <!-- Fare -->
    <VBox spacing="5">
        <Label text="Fare Paid (PHP)"
               style="-fx-font-weight: bold; -fx-text-fill: #475569;"/>
        <TextField fx:id="fareField"
                   promptText="e.g. 250.00"
                   styleClass="text-field"/>
    </VBox>

    <!-- Warning label (validation) -->
    <Label fx:id="warningLabel"
           text=""
           style="-fx-text-fill: #E11D48; -fx-font-size: 12px;"
           visible="false" managed="false" wrapText="true"/>

    <Region VBox.vgrow="ALWAYS"/>

    <HBox spacing="10" alignment="CENTER_RIGHT">
        <Button text="Cancel" onAction="#handleCancel"
                style="-fx-background-color: transparent;
                       -fx-border-color: #CBD5E1; -fx-border-radius: 8;
                       -fx-background-radius: 8; -fx-padding: 8 20;
                       -fx-cursor: hand;"/>
        <Button text="Confirm Boarding" onAction="#handleSave"
                styleClass="primary-button"
                style="-fx-padding: 8 20;"/>
    </HBox>
</VBox>