<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.geometry.Insets?>
<?import java.net.URL?>

<VBox spacing="20" styleClass="login-card" stylesheets="@style.css"
      xmlns="http://javafx.com/javafx/17" xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="com.biyahero.controller.SeatPlanController"
      prefWidth="450"> <padding>
    <Insets top="30" right="30" bottom="30" left="30"/>
</padding>

    <VBox spacing="5" alignment="CENTER">
        <Label text="Select a Seat" styleClass="header-title"/>
        <Label text="Select route segment, then choose an available seat." styleClass="sub-header"/>
    </VBox>

    <HBox spacing="15" alignment="CENTER">
        <VBox spacing="5" HBox.hgrow="ALWAYS">
            <Label text="Pick-up Stop" style="-fx-font-size: 12px; -fx-text-fill: #64748B; -fx-font-weight: bold;"/>
            <ComboBox fx:id="cbPickupStop" promptText="Select Origin" maxWidth="Infinity"/>
        </VBox>
        <VBox spacing="5" HBox.hgrow="ALWAYS">
            <Label text="Drop-off Stop" style="-fx-font-size: 12px; -fx-text-fill: #64748B; -fx-font-weight: bold;"/>
            <ComboBox fx:id="cbDropoffStop" promptText="Select Destination" maxWidth="Infinity"/>
        </VBox>
    </HBox>

    <StackPane style="-fx-background-color: #F4F7FA; -fx-background-radius: 15; -fx-padding: 20;">
        <GridPane fx:id="seatGrid" hgap="15" vgap="15" alignment="CENTER"/>
    </StackPane>

    <HBox spacing="20" alignment="CENTER">
        <HBox spacing="5" alignment="CENTER">
            <Region style="-fx-background-color: #22C55E; -fx-pref-width: 15; -fx-pref-height: 15; -fx-background-radius: 3;"/>
            <Label text="Available" styleClass="sub-header"/>
        </HBox>
        <HBox spacing="5" alignment="CENTER">
            <Region style="-fx-background-color: #F1C40F; -fx-pref-width: 15; -fx-pref-height: 15; -fx-background-radius: 3;"/>
            <Label text="Occupied" styleClass="sub-header"/>
        </HBox>
    </HBox>
</VBox>