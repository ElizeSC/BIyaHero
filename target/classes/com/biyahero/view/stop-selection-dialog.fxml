<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.geometry.*?>
<?import java.net.URL?>

<!-- Replaced main-container with login-card for proper dialog surface -->
<VBox spacing="20" styleClass="login-card"
      xmlns="http://javafx.com/javafx/17"
      xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="com.biyahero.controller.StopSelectionController"
      prefWidth="380">
    <stylesheets><URL value="@style.css"/></stylesheets>
    <padding><Insets top="30" right="30" bottom="30" left="30"/></padding>

    <VBox spacing="5">
        <!-- Replaced inline font/weight/color with header-title class -->
        <Label text="Update Van Location" styleClass="header-title"/>
        <Label text="Select the stop the van has just reached." styleClass="sub-header"/>
    </VBox>

    <Separator/>

    <VBox spacing="4">
        <!-- Replaced inline bold/color with input-label class -->
        <Label text="Current Stop" styleClass="input-label"/>
        <!-- Replaced inline color/size with sub-header class -->
        <Label fx:id="currentStopLabel" text="Departed — no stop reached yet" styleClass="sub-header"/>
    </VBox>

    <VBox spacing="8">
        <Label text="Move van to:" styleClass="input-label"/>
        <!-- Removed inline -fx-font-size:14; combo-box CSS handles font -->
        <ComboBox fx:id="stopComboBox" maxWidth="Infinity"
                  promptText="Select next stop..." styleClass="combo-box"/>
        <!-- Kept inline color: this is a semantic error state label -->
        <Label fx:id="noStopsLabel"
               text="⚠ Van is already at the final stop."
               styleClass="error-text"
               visible="false" managed="false"/>
    </VBox>

    <!-- Kept inline styles: amber warning banner is a unique one-off state with no CSS class -->
    <Label fx:id="finalStopWarning"
           text="⚠ Selecting this stop will mark the trip as Completed."
           style="-fx-text-fill: #D97706; -fx-font-size: 12px;
                  -fx-background-color: #FEF3C7; -fx-background-radius: 6;
                  -fx-padding: 8 12;"
           visible="false" managed="false" wrapText="true"/>

    <Region VBox.vgrow="ALWAYS"/>

    <HBox spacing="10" alignment="CENTER_RIGHT">
        <!-- Replaced fully inline Cancel with btn-secondary class -->
        <Button text="Cancel" onAction="#handleCancel" styleClass="btn-secondary"/>
        <!-- Removed conflicting inline -fx-padding overriding primary-button CSS -->
        <Button fx:id="confirmButton" text="Confirm Update"
                onAction="#handleConfirm" styleClass="primary-button"/>
    </HBox>
</VBox>