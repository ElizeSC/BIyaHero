<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.geometry.*?>
<?import java.net.URL?>

<VBox spacing="20" styleClass="main-container"
      xmlns="http://javafx.com/javafx/17"
      xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="com.biyahero.controller.StopSelectionController"
      prefWidth="380">
    <stylesheets><URL value="@style.css"/></stylesheets>
    <padding><Insets top="30" right="30" bottom="30" left="30"/></padding>

    <!-- Header -->
    <VBox spacing="5">
        <Label text="Update Van Location"
               style="-fx-font-size: 20px; -fx-font-weight: 900; -fx-text-fill: #0A0D2C;"/>
        <Label text="Select the stop the van has just reached."
               styleClass="sub-header"/>
    </VBox>

    <Separator/>

    <!-- Current position info -->
    <VBox spacing="4">
        <Label text="Current Stop" style="-fx-font-weight: bold; -fx-text-fill: #475569;"/>
        <Label fx:id="currentStopLabel"
               text="Departed — no stop reached yet"
               style="-fx-text-fill: #7E869E; -fx-font-size: 13px;"/>
    </VBox>

    <!-- Next stop picker -->
    <VBox spacing="8">
        <Label text="Move van to:" style="-fx-font-weight: bold; -fx-text-fill: #475569;"/>
        <ComboBox fx:id="stopComboBox" maxWidth="Infinity"
                  promptText="Select next stop..."
                  style="-fx-font-size: 14px;"/>
        <Label fx:id="noStopsLabel"
               text="⚠ Van is already at the final stop."
               style="-fx-text-fill: #E11D48; -fx-font-size: 12px;"
               visible="false" managed="false"/>
    </VBox>

    <!-- Warning when last stop is selected -->
    <Label fx:id="finalStopWarning"
           text="⚠ Selecting this stop will mark the trip as Completed."
           style="-fx-text-fill: #D97706; -fx-font-size: 12px;
                  -fx-background-color: #FEF3C7; -fx-background-radius: 6;
                  -fx-padding: 8 12;"
           visible="false" managed="false" wrapText="true"/>

    <Region VBox.vgrow="ALWAYS"/>

    <!-- Buttons -->
    <HBox spacing="10" alignment="CENTER_RIGHT">
        <Button text="Cancel"
                onAction="#handleCancel"
                style="-fx-background-color: transparent;
                       -fx-border-color: #CBD5E1; -fx-border-radius: 8;
                       -fx-background-radius: 8; -fx-padding: 8 20;
                       -fx-cursor: hand;"/>
        <Button fx:id="confirmButton"
                text="Confirm Update"
                onAction="#handleConfirm"
                styleClass="primary-button"
                style="-fx-padding: 8 20;"/>
    </HBox>
</VBox>