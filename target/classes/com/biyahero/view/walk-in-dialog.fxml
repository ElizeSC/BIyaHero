<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.geometry.*?>
<?import java.net.URL?>

<!-- Replaced main-container with login-card for proper dialog surface -->
<VBox spacing="20" styleClass="login-card"
      xmlns="http://javafx.com/javafx/17"
      xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="com.biyahero.controller.WalkInBookingController"
      prefWidth="380">
    <stylesheets><URL value="@style.css"/></stylesheets>
    <padding><Insets top="30" right="30" bottom="30" left="30"/></padding>

    <VBox spacing="5">
        <!-- Replaced inline font/weight/color with header-title class -->
        <Label text="Quick Boarding" styleClass="header-title"/>
        <Label text="Roadside walk-in — no personal info needed." styleClass="sub-header"/>
    </VBox>

    <Separator/>

    <HBox alignment="CENTER_LEFT" spacing="12">
        <!-- Replaced inline bold/color with input-label class -->
        <Label text="Seat:" styleClass="input-label"/>
        <!-- Kept inline styles: this seat badge is a unique one-off visual pill -->
        <Label fx:id="seatNumberLabel" text="—"
               style="-fx-font-size: 22px; -fx-font-weight: 900;
                      -fx-text-fill: #3E49BB;
                      -fx-background-color: #EEF2FF;
                      -fx-background-radius: 8;
                      -fx-padding: 4 16;"/>
    </HBox>

    <GridPane hgap="15" vgap="12">
        <columnConstraints>
            <ColumnConstraints percentWidth="50"/>
            <ColumnConstraints percentWidth="50"/>
        </columnConstraints>

        <VBox GridPane.columnIndex="0" GridPane.rowIndex="0" spacing="5">
            <Label text="Pickup Stop" styleClass="input-label"/>
            <ComboBox fx:id="pickupStopCombo" maxWidth="Infinity" promptText="Boarded at..." styleClass="combo-box"/>
        </VBox>

        <VBox GridPane.columnIndex="1" GridPane.rowIndex="0" spacing="5">
            <Label text="Dropoff Stop" styleClass="input-label"/>
            <ComboBox fx:id="dropoffStopCombo" maxWidth="Infinity" promptText="Getting off at..." styleClass="combo-box"/>
        </VBox>
    </GridPane>

    <VBox spacing="5">
        <Label text="Fare Paid (PHP)" styleClass="input-label"/>
        <TextField fx:id="fareField" promptText="e.g. 250.00" styleClass="text-field"/>
    </VBox>

    <!-- Kept inline color: error/warning labels are dynamic semantic states, not layout -->
    <Label fx:id="warningLabel" text="" styleClass="error-text"
           visible="false" managed="false" wrapText="true"/>

    <Region VBox.vgrow="ALWAYS"/>

    <HBox spacing="10" alignment="CENTER_RIGHT">
        <!-- Replaced fully inline Cancel with btn-secondary class -->
        <Button text="Cancel" onAction="#handleCancel" styleClass="btn-secondary"/>
        <!-- Removed conflicting inline -fx-padding overriding primary-button CSS -->
        <Button text="Confirm Boarding" onAction="#handleSave" styleClass="primary-button"/>
    </HBox>
</VBox>