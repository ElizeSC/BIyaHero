<?xml version="1.0" encoding="UTF-8"?>

<?import java.net.URL?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.Font?>

<ScrollPane fitToWidth="true" style="-fx-background-color: #f8fafc;" xmlns="http://javafx.com/javafx/17" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.biyahero.controller.ReportsController">
    <stylesheets>
        <URL value="@style.css" />
    </stylesheets>
    <content>
        <VBox spacing="25.0" style="-fx-background-color: #f8fafc;">
            <padding>
                <Insets bottom="30.0" left="40.0" right="40.0" top="30.0" />
            </padding>
            <children>

                <VBox spacing="5.0">
                    <children>
                        <Label text="Trip Data Reports" textFill="#3498db">
                            <font><Font name="System Bold" size="32.0" /></font>
                        </Label>
                        <Label text="Preview and export trip records." textFill="#64748b" />
                    </children>
                </VBox>

                <HBox spacing="20.0" alignment="TOP_CENTER">
                    <children>
                        <VBox spacing="15.0" styleClass="filter-card" HBox.hgrow="ALWAYS">
                            <children>
                                <HBox spacing="20.0">
                                    <children>
                                        <VBox spacing="5.0">
                                            <Label text="Start Date" />
                                            <DatePicker fx:id="startDatePicker" prefHeight="35.0" />
                                        </VBox>
                                        <VBox spacing="5.0">
                                            <Label text="End Date" />
                                            <DatePicker fx:id="endDatePicker" prefHeight="35.0" />
                                        </VBox>
                                    </children>
                                </HBox>

                                <Label text="or:" textFill="#94a3b8" />

                                <HBox spacing="10.0" alignment="CENTER_LEFT">
                                    <children>
                                        <Button onAction="#handleTripReportPopup" styleClass="btn-generate-outline" text="Generate Trip Report" />
                                        <Label text="This will export data about specific trip including customer manifest" textFill="#94a3b8" style="-fx-font-size: 10px;" />
                                    </children>
                                </HBox>
                            </children>
                        </VBox>

                        <VBox spacing="10.0" prefWidth="220.0">
                            <children>
                                <Button maxWidth="Infinity" onAction="#exportToCSV" styleClass="btn-action" text="Generate CSV Report" />
                                <Button maxWidth="Infinity" onAction="#exportToJSON" styleClass="btn-action" text="Generate JSON Report" />
                                <Button maxWidth="Infinity" onAction="#exportToSQL" styleClass="btn-action-alt" text="Generate SQL Backup File" />
                            </children>
                        </VBox>
                    </children>
                </HBox>

                <HBox spacing="20.0">
                    <children>
                        <VBox styleClass="stat-card" HBox.hgrow="ALWAYS">
                            <Label text="Total Trips" />
                            <Label fx:id="totalTripsLabel" text="0" style="-fx-font-size: 22px; -fx-font-weight: bold;" />
                        </VBox>
                        <VBox styleClass="stat-card" HBox.hgrow="ALWAYS">
                            <Label text="Average Occupancy" />
                            <Label fx:id="avgOccupancyLabel" text="0%" style="-fx-font-size: 22px; -fx-font-weight: bold;" />
                        </VBox>
                        <VBox styleClass="stat-card" HBox.hgrow="ALWAYS">
                            <Label text="Total Revenue" />
                            <Label fx:id="totalRevenueLabel" text="₱0.00" textFill="#27ae60" style="-fx-font-size: 22px; -fx-font-weight: bold;" />
                        </VBox>
                    </children>
                </HBox>

                <VBox spacing="10.0">
                    <children>
                        <HBox alignment="BOTTOM_LEFT">
                            <Label fx:id="tableRangeLabel" text="Trips from [Start Date] to [End Date]" textFill="#3498db" style="-fx-font-size: 18px;" />
                            <Region HBox.hgrow="ALWAYS" />
                            <Label text="Sort by: " />
                            <ComboBox fx:id="sortComboBox" prefWidth="120.0" promptText="Trip ID" />
                        </HBox>
                        <TableView fx:id="reportsTable" prefHeight="400.0" styleClass="modern-table">
                            <columns>
                                <TableColumn fx:id="colTripId" text="Trip ID" prefWidth="80" />
                                <TableColumn fx:id="colDriver" text="Driver" prefWidth="150" />
                                <TableColumn fx:id="colRoute" text="Route" prefWidth="200" />
                                <TableColumn fx:id="colDate" text="Date" prefWidth="120" />
                                <TableColumn fx:id="colOccupancy" text="Occupancy" prefWidth="100" />
                                <TableColumn fx:id="colRevenue" text="Revenue" prefWidth="100" />
                            </columns>
                            <columnResizePolicy>
                                <TableView fx:constant="CONSTRAINED_RESIZE_POLICY" />
                            </columnResizePolicy>
                        </TableView>
                    </children>
                </VBox>
            </children>
        </VBox>
    </content>
</ScrollPane>