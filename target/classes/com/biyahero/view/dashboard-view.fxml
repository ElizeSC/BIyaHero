<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<VBox spacing="20" style="-fx-padding: 30; -fx-background-color: #ecf0f1;"
      xmlns="http://javafx.com/javafx/8"
      xmlns:fx="http://javafx.com/fxml/1">
    <Label text="Active Trips" style="-fx-font-size: 26; -fx-font-weight: bold; -fx-text-fill: #2c3e50;"/>

    <VBox spacing="10" style="-fx-background-color: white; -fx-padding: 20; -fx-background-radius: 15;">
        <HBox alignment="CENTER_LEFT">
            <VBox>
                <Label text="Trip #1042" style="-fx-font-weight: bold; -fx-font-size: 18;"/>
                <Label text="Van: BiyaHero Express (NVD-123)" style="-fx-text-fill: #7f8c8d;"/>
            </VBox>
            <Region HBox.hgrow="ALWAYS" />
            <Button text="View Details" style="-fx-background-color: #3498db; -fx-text-fill: white;"/>
        </HBox>

        <Separator />

        <HBox spacing="15" alignment="CENTER" style="-fx-padding: 10;">
            <Label text="Station A" style="-fx-font-weight: bold; -fx-text-fill: #27ae60;"/>
            <Label text="▶▶▶" />
            <Label text="Station B" />
            <Label text="▶▶▶" />
            <Label text="Station C" />
        </HBox>
    </VBox>
</VBox>