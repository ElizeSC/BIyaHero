<?xml version="1.0" encoding="UTF-8"?>

<?import java.net.*?>
<?import javafx.geometry.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<VBox prefWidth="450.0" spacing="20" styleClass="main-container" xmlns="http://javafx.com/javafx/17.0.12" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.biyahero.controller.AddDriverController">

    <stylesheets>
        <URL value="@style.css" />
    </stylesheets>

    <padding>
        <Insets bottom="30" left="40" right="40" top="30" />
    </padding>

    <VBox spacing="5">
        <Label fx:id="titleLabel" styleClass="header-title" text="Register New Driver" style="-fx-font-size: 22px;" />
        <Label styleClass="sub-header" text="Fill in the driver's credential information." />
    </VBox>

    <Separator />

    <VBox spacing="15">
        <VBox spacing="5">
            <Label style="-fx-font-weight: bold;" text="Full Name" />
            <TextField fx:id="nameField" promptText="e.g. Juan Dela Cruz" />
        </VBox>

        <VBox spacing="5">
            <Label style="-fx-font-weight: bold;" text="License Number" />
            <TextField fx:id="licenseField" promptText="e.g. N01-XX-XXXXXX" />
        </VBox>

        <VBox spacing="5">
            <Label style="-fx-font-weight: bold;" text="Contact Number" />
            <TextField fx:id="contactField" promptText="e.g. 0917 123 4567" />
        </VBox>

        <VBox spacing="5">
            <Label style="-fx-font-weight: bold;" text="Status" />
            <ComboBox fx:id="statusComboBox" prefWidth="400.0" promptText="Select Status" />
        </VBox>
    </VBox>

    <Region VBox.vgrow="ALWAYS" />

    <HBox alignment="CENTER_RIGHT" spacing="15">
        <Button onAction="#handleCancel" style="-fx-background-color: transparent; -fx-text-fill: #636e72;" text="Cancel" />
        <Button onAction="#handleSave" styleClass="primary-button" text="Save Driver" />
    </HBox>

</VBox>