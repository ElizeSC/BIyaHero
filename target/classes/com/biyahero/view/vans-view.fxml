<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import java.net.URL?>

<VBox spacing="20" styleClass="main-container" xmlns="http://javafx.com/javafx/17.0.12"
      xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="com.biyahero.controller.VanDriverController">

    <stylesheets>
        <URL value="@style.css" />
    </stylesheets>

    <padding>
        <Insets bottom="30" left="30" right="30" top="30" />
    </padding>

    <HBox alignment="CENTER_LEFT">
        <VBox spacing="5">
            <Label styleClass="header-title" text="Vans and Drivers" />
            <Label styleClass="sub-header" text="Manage Van and Driver Records" />
        </VBox>
        <Region HBox.hgrow="ALWAYS" />

        <HBox styleClass="nav-bar">
            <Button fx:id="btnVans"
                    styleClass="primary-button"
                    text="Vans"
                    onAction="#showVanTable" /> <Button fx:id="btnDrivers"
                                                        style="-fx-background-color: transparent; -fx-text-fill: #2f3640;"
                                                        text="Drivers"
                                                        onAction="#showDriverTable" /> </HBox>
    </HBox>

    <HBox alignment="CENTER_LEFT" spacing="15">
        <TextField fx:id="searchField" promptText="Search Van..." prefWidth="250" />
        <ComboBox promptText="Display Van Information" prefWidth="200" />
        <Region HBox.hgrow="ALWAYS" />
        <Button styleClass="primary-button" text="+ Add Van" />
    </HBox>

    <HBox alignment="CENTER_LEFT" spacing="10">
        <Label styleClass="sub-header" text="Sort by:" />
        <ComboBox promptText="Van ID" prefWidth="120" />
    </HBox>

    <StackPane VBox.vgrow="ALWAYS">
        <TableView fx:id="vanTable">
            <columns>
                <TableColumn fx:id="colVanId" text="Van ID" prefWidth="120" />
                <TableColumn fx:id="colPlate" text="Plate Number" prefWidth="150" />
                <TableColumn fx:id="colModel" text="Model" prefWidth="150" />
                <TableColumn fx:id="colCapacity" text="Capacity" prefWidth="100" />
                <TableColumn fx:id="colStatus" text="Status" prefWidth="120" />
            </columns>
        </TableView>

        <TableView fx:id="driverTable" visible="false">
            <columns>
                <TableColumn fx:id="colDriverId" text="Driver ID" prefWidth="120" />
                <TableColumn fx:id="colDriverName" text="Name" prefWidth="200" />
                <TableColumn fx:id="colLicense" text="License #" prefWidth="150" />
                <TableColumn fx:id="colContact" text="Contact" prefWidth="150" />
            </columns>
        </TableView>
    </StackPane>
</VBox>