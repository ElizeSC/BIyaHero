<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<VBox spacing="20" style="-fx-padding: 30;" xmlns="http://javafx.com/javafx/8" xmlns:fx="http://javafx.com/fxml/1">
    <Label text="Vans &amp; Drivers Management" style="-fx-font-size: 24; -fx-font-weight: bold;"/>

    <TableView VBox.vgrow="ALWAYS">
        <columns>
            <TableColumn text="Plate Number" prefWidth="150" />
            <TableColumn text="Driver Name" prefWidth="200" />
            <TableColumn text="Status" prefWidth="100" />
            <TableColumn text="Last Trip" prefWidth="150" />
        </columns>
    </TableView>
</VBox>