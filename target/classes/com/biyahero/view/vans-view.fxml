<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import java.net.URL?>

<VBox spacing="20" styleClass="main-container" xmlns="http://javafx.com/javafx/17.0.12"
      xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="com.biyahero.controller.VanDriverController">

    <stylesheets>
        <URL value="@style.css" />
    </stylesheets>

    <padding>
        <Insets bottom="30" left="30" right="30" top="30" />
    </padding>

    <HBox alignment="CENTER_LEFT">
        <VBox spacing="5">
            <Label styleClass="header-title" text="Vans and Drivers" />
            <Label styleClass="sub-header" text="Manage Van and Driver Records" />
        </VBox>
        <Region HBox.hgrow="ALWAYS" />

        <HBox styleClass="nav-bar">
            <Button styleClass="primary-button" text="Vans" />
            <Button style="-fx-background-color: transparent; -fx-text-fill: #2f3640;" text="Drivers" />
        </HBox>
    </HBox>

    <HBox alignment="CENTER_LEFT" spacing="15">
        <TextField fx:id="searchField" promptText="Search Van..." prefWidth="250" />
        <ComboBox promptText="Display Van Information" prefWidth="200" />
        <Region HBox.hgrow="ALWAYS" />
        <Button styleClass="primary-button" text="+ Add Van" />
    </HBox>

    <HBox alignment="CENTER_LEFT" spacing="10">
        <Label styleClass="sub-header" text="Sort by:" />
        <ComboBox promptText="Van ID" prefWidth="120" />
    </HBox>

    <TableView fx:id="vanTable" VBox.vgrow="ALWAYS">
        <columns>
            <TableColumn fx:id="colVanId" prefWidth="120" text="Van ID" />
            <TableColumn fx:id="colPlate" prefWidth="150" text="Plate Number" />
            <TableColumn fx:id="colModel" prefWidth="150" text="Model" />
            <TableColumn fx:id="colCapacity" prefWidth="100" text="Capacity" />
            <TableColumn fx:id="colStatus" prefWidth="120" text="Status" />
            <TableColumn prefWidth="180" text="Manage" />
        </columns>
    </TableView>
</VBox>