<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.geometry.Insets?>
<?import java.net.URL?>

<StackPane prefHeight="600.0" prefWidth="800.0" styleClass="login-root" xmlns="http://javafx.com/javafx"
           xmlns:fx="http://javafx.com/fxml"
           fx:controller="com.biyahero.controller.RegistrationController">

    <stylesheets>
        <URL value="@style.css" />
    </stylesheets>

    <VBox alignment="CENTER" spacing="20">
        <VBox alignment="CENTER" spacing="10" styleClass="login-card" maxWidth="400">
            <padding>
                <Insets top="40" right="40" bottom="40" left="40" />
            </padding>

            <Label text="B" styleClass="login-logo-icon" />
            <Label text="Create Account" styleClass="login-header-title" />
            <Label text="BiyaHero Dispatcher System" styleClass="login-subtitle" />

            <Region prefHeight="20" />

            <VBox spacing="15" alignment="CENTER_LEFT">
                <VBox spacing="5">
                    <Label text="Full Name" styleClass="input-label" />
                    <TextField fx:id="nameField" promptText="Enter your full name" styleClass="login-input" />
                </VBox>

                <VBox spacing="5">
                    <Label text="Username" styleClass="input-label" />
                    <TextField fx:id="usernameField" promptText="Choose a username" styleClass="login-input" />
                </VBox>

                <VBox spacing="5">
                    <Label text="Password" styleClass="input-label" />
                    <PasswordField fx:id="passwordField" promptText="Create a password" styleClass="login-input" />
                </VBox>
            </VBox>

            <Region prefHeight="10" />

            <Button text="Sign Up" onAction="#handleRegister" maxWidth="Infinity" styleClass="login-button" />

            <HBox alignment="CENTER" spacing="5">
                <Label text="Already have an account?" style="-fx-text-fill: #7E869E;"/>
                <Button text="Login" onAction="#handleBackToLogin"
                        style="-fx-background-color: transparent; -fx-text-fill: #3E49BB; -fx-font-weight: bold; -fx-cursor: hand;"/>
            </HBox>

        </VBox>
    </VBox>
</StackPane>