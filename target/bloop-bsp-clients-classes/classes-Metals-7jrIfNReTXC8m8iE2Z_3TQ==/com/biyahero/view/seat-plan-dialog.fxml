<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.geometry.Insets?>
<?import java.net.URL?>

<!-- Replaced main-container with login-card for proper dialog surface -->
<VBox spacing="20" styleClass="login-card" stylesheets="@style.css"
      xmlns="http://javafx.com/javafx/17" xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="com.biyahero.controller.SeatPlanController"
      prefWidth="350">

    <padding>
        <Insets top="30" right="30" bottom="30" left="30"/>
    </padding>

    <VBox spacing="5" alignment="CENTER">
        <!-- Removed inline -fx-font-size:22 fighting header-title CSS -->
        <Label text="Select a Seat" styleClass="header-title"/>
        <Label text="Choose an available seat (Green) to book." styleClass="sub-header"/>
    </VBox>

    <!-- Kept inline styles here: this is a one-off container with no matching CSS class -->
    <StackPane style="-fx-background-color: #F4F7FA; -fx-background-radius: 15; -fx-padding: 20;">
        <GridPane fx:id="seatGrid" hgap="15" vgap="15" alignment="CENTER"/>
    </StackPane>

    <!-- Legend — kept inline color swatches since these are purely decorative indicators -->
    <HBox spacing="20" alignment="CENTER">
        <HBox spacing="5" alignment="CENTER">
            <Region style="-fx-background-color: #22C55E; -fx-pref-width: 15; -fx-pref-height: 15; -fx-background-radius: 3;"/>
            <Label text="Available" styleClass="sub-header"/>
        </HBox>
        <HBox spacing="5" alignment="CENTER">
            <Region style="-fx-background-color: #FACC15; -fx-pref-width: 15; -fx-pref-height: 15; -fx-background-radius: 3;"/>
            <Label text="Booked" styleClass="sub-header"/>
        </HBox>
    </HBox>

    <HBox alignment="CENTER">
        <Button text="Close" onAction="#handleClose" styleClass="btn-secondary" prefWidth="100"/>
    </HBox>
</VBox>